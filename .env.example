# --- MediSync Environment Configuration Template ---

# Node environment (development or production)
NODE_ENV=production

# Server listening port (default is 5000)
PORT=5000

# JSON Web Token Secret key (mandatory in production)
JWT_SECRET=your_super_secret_jwt_sign_key_here

# MongoDB Connection String (e.g. MongoDB Atlas)
# Leave blank to fall back to local db.json storage (lowdb)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/medisync?retryWrites=true&w=majority

# Cloudinary Upload Credentials (Optional)
# Leave blank to store uploads locally in /tmp/uploads or /uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend Configuration (for client builds)
# Points Vercel client to the backend hosting URL (optional, defaults to relative route)
VITE_API_URL=
